[Unit]
Description=KernelSentinel control daemon
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/kernelsentinel-daemon --listen 0.0.0.0:50051 --stub-runtime=false
Restart=on-failure
AmbientCapabilities=CAP_BPF CAP_NET_ADMIN CAP_PERFMON CAP_SYS_RESOURCE

[Install]
WantedBy=multi-user.target
